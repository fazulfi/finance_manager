{
  "extends": "@finance/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@finance/ui": ["../../packages/ui/src/index.ts"],
      "@finance/types": ["../../packages/types/src/index.ts"],
      "@finance/utils": ["../../packages/utils/src/index.ts"],
      "@finance/api": ["../../packages/api/src/index.ts"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
