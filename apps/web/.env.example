# Database (MongoDB connection string)
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/financeflow?retryWrites=true&w=majority"

# NextAuth.js v5
# Generate with: openssl rand -base64 32  (use AUTH_SECRET for v5)
AUTH_SECRET="your-auth-secret-generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="your-nextauth-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Google OAuth (get credentials from console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
