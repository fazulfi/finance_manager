{
  "name": "@finance/api",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.tsx",
      "default": "./src/react.tsx"
    },
    "./root": {
      "types": "./src/root.ts",
      "default": "./src/root.ts"
    },
    "./trpc": {
      "types": "./src/trpc.ts",
      "default": "./src/trpc.ts"
    }
  },
  "scripts": {
    "build": "tsc",
