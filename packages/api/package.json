    "@trpc/next": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "@finance/types": "workspace:*",
    "superjson": "^2.2.2",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@finance/db": "workspace:*",
    "@tanstack/react-query": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@finance/db": "workspace:*",
    "@finance/eslint-config": "workspace:*",
    "@finance/tsconfig": "workspace:*",
    "@tanstack/react-query": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.6.3"
  }
